---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="關於 — Eric Wu" description="關於 Eric Wu 和這個 blog">
  <div class="max-w-[720px] mx-auto px-6 md:px-8 py-12">
    <h1 class="text-[2rem] font-bold mb-8">關於我</h1>

    <div class="prose">
      <p>
        我是 Eric Wu，寫科技產業分析的。
      </p>
      <p>
        這個 blog 主要有兩類內容：<strong>深度分析</strong>是針對特定公司、產品或趨勢的長文分析；<strong>本週科技</strong>是每週的科技新聞整理和評論。
      </p>
      <p>
        如果你對這些主題有興趣，可以訂閱我的電子報，每週寄送到你的信箱。
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-lg font-semibold mb-4">聯絡方式</h2>
      <ul class="space-y-2 text-text-secondary">
        <li>
          Threads：<a href="https://www.threads.com/?hl=zh-tw" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Threads</a>
        </li>
        <li>
          Substack：<a href="https://eric479694.substack.com/embed" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">訂閱電子報</a>
        </li>
        <li>
          GitHub：<a href="https://github.com/skynocover" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">skynocover</a>
        </li>
      </ul>
    </div>
  </div>
</BaseLayout>
