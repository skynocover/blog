---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCTA from '../../components/ArticleCTA.astro';
import PostNav from '../../components/PostNav.astro';
import { getCollection, render } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';
import { formatDate } from '../../utils/format-date';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );

  return posts.map((post, index) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: {
      post,
      prev: index < posts.length - 1 ? posts[index + 1] : null,
      next: index > 0 ? posts[index - 1] : null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body);
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 2;
---

<BaseLayout
  title={`${post.data.title} — Eric Wu`}
  description={post.data.description}
  ogType="article"
>
  <div id="progress-bar" class="fixed top-0 left-0 h-0.5 bg-accent z-50" style="width: 0%"></div>
  <div class="relative max-w-180 mx-auto px-6 md:px-8">
    <article>
      <header class="pt-12 pb-8">
        <div class="text-sm text-text-secondary mb-4">
          {post.data.tag} · <time datetime={post.data.date.toISOString()}
            >{formatDate(post.data.date)}</time
          > · {readingTime} 分鐘閱讀
        </div>
        <h1 class="text-[2rem] font-bold leading-tight">
          {post.data.title}
        </h1>
      </header>

      <div class="prose">
        <Content />
      </div>

      <ArticleCTA />
      <PostNav prev={prev} next={next} />
    </article>

    {showToc && (
      <aside class="hidden xl:block absolute top-0 bottom-0 left-full ml-8 w-48">
        <nav id="toc-nav" class="sticky top-24 pt-32">
          <h4 class="text-xs font-semibold text-text-secondary uppercase tracking-wide mb-3">目錄</h4>
          <ul class="space-y-2 border-l border-border">
            {tocHeadings.map((heading) => (
              <li>
                <a
                  href={`#${heading.slug}`}
                  class:list={[
                    'toc-link block text-sm leading-snug py-0.5 border-l-2 border-transparent -ml-px transition-colors text-text-secondary hover:text-accent',
                    heading.depth === 3 ? 'pl-6' : 'pl-3',
                  ]}
                  data-slug={heading.slug}
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}
  </div>
  <script>
    let cleanupProgressBar: (() => void) | null = null;

    function initProgressBar() {
      cleanupProgressBar?.();
      cleanupProgressBar = null;

      const bar = document.getElementById('progress-bar');
      if (!bar) return;

      const controller = new AbortController();

      const updateProgress = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
        bar.style.width = `${progress}%`;
      }

      window.addEventListener('scroll', updateProgress, { passive: true, signal: controller.signal });
      updateProgress();

      cleanupProgressBar = () => controller.abort();
    }

    document.addEventListener('astro:page-load', initProgressBar);
  </script>
  <script>
    let cleanupToc: (() => void) | null = null;

    function initToc() {
      cleanupToc?.();
      cleanupToc = null;

      const nav = document.getElementById('toc-nav');
      if (!nav) return;

      const links = nav.querySelectorAll<HTMLAnchorElement>('.toc-link');
      const slugs = Array.from(links).map((l) => l.dataset.slug!);
      const headingEls = slugs
        .map((s) => document.getElementById(s))
        .filter(Boolean) as HTMLElement[];

      if (headingEls.length === 0) return;

      const visibleIds = new Set<string>();

      function setActive(slug: string) {
        links.forEach((link) => {
          const isActive = link.dataset.slug === slug;
          link.classList.toggle('text-text-secondary', !isActive);
          link.classList.toggle('text-accent', isActive);
          link.classList.toggle('border-transparent', !isActive);
          link.classList.toggle('border-accent', isActive);
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              visibleIds.add(entry.target.id);
            } else {
              visibleIds.delete(entry.target.id);
            }
          }
          const active = slugs.find((s) => visibleIds.has(s));
          if (active) setActive(active);
        },
        { rootMargin: '0px 0px -70% 0px' },
      );

      headingEls.forEach((el) => observer.observe(el));

      const controller = new AbortController();
      links.forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const target = document.getElementById(link.dataset.slug!);
          target?.scrollIntoView({ behavior: 'smooth' });
        }, { signal: controller.signal });
      });

      cleanupToc = () => {
        observer.disconnect();
        controller.abort();
      };
    }

    document.addEventListener('astro:page-load', initToc);
  </script>
</BaseLayout>
