---
import { ClientRouter } from 'astro:transitions';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
  publishedDate?: Date;
  image?: string;
}

const {
  title,
  description = '科技產業分析・每週更新',
  ogType = 'website',
  publishedDate,
  image,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = image
  ? new URL(image, Astro.site).href
  : new URL('/og-default.png', Astro.site).href;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Eric Wu" href="/rss.xml" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Noto+Sans+TC:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Eric Wu" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:image" content={ogImageURL} />
    {
      publishedDate && (
        <meta property="article:published_time" content={publishedDate.toISOString()} />
      )
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD -->
    {
      ogType === 'article' && publishedDate && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'Article',
            headline: title,
            description: description,
            datePublished: publishedDate.toISOString(),
            url: canonicalURL.href,
            image: ogImageURL,
            author: {
              '@type': 'Person',
              name: 'Eric Wu',
              url: 'https://ericwu.co',
            },
            publisher: {
              '@type': 'Person',
              name: 'Eric Wu',
              url: 'https://ericwu.co',
            },
          })}
        />
      )
    }
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
