---

<div class="flex gap-2 mb-8" id="tag-filter">
  <button
    class="tag-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors"
    data-tag="all"
  >
    全部
  </button>
  <button
    class="tag-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors"
    data-tag="科技觀察"
  >
    科技觀察
  </button>
  <button
    class="tag-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors"
    data-tag="技術筆記"
  >
    技術筆記
  </button>
  <button
    class="tag-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors"
    data-tag="隨筆"
  >
    隨筆
  </button>
</div>

<style>
  .tag-btn {
    background-color: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    border: 1px solid var(--color-border);
  }
  .tag-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text-secondary);
  }
  .tag-btn.active {
    background-color: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }
</style>

<script>
  let cleanupTagFilter: (() => void) | null = null;

  function filterByTag(
    tag: string,
    buttons: NodeListOf<HTMLButtonElement>,
    articles: NodeListOf<HTMLElement>,
  ) {
    buttons.forEach((b) => b.classList.toggle('active', b.dataset.tag === tag));

    articles.forEach((article) => {
      if (tag === 'all' || article.dataset.postTag === tag) {
        article.style.display = '';
      } else {
        article.style.display = 'none';
      }
    });
  }

  function initTagFilter() {
    cleanupTagFilter?.();
    cleanupTagFilter = null;

    const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
    const articles = document.querySelectorAll<HTMLElement>('[data-post-tag]');
    if (buttons.length === 0) return;

    filterByTag('科技觀察', buttons, articles);

    const controller = new AbortController();
    buttons.forEach((btn) => {
      btn.addEventListener(
        'click',
        () => {
          filterByTag(btn.dataset.tag!, buttons, articles);
        },
        { signal: controller.signal },
      );
    });

    cleanupTagFilter = () => controller.abort();
  }

  document.addEventListener('astro:page-load', initTagFilter);
</script>
