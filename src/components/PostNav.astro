---
import type { CollectionEntry } from 'astro:content';
import { postUrl } from '../utils/post-url';

interface Props {
  prev: CollectionEntry<'posts'> | null;
  next: CollectionEntry<'posts'> | null;
}

const { prev, next } = Astro.props;
---

{
  (prev || next) && (
    <nav class="border-t border-border mt-8 pt-8 flex justify-between items-start gap-8">
      <div class="flex-1 min-w-0">
        {prev && (
          <a href={postUrl(prev.id)} class="group block">
            <span class="text-sm text-text-secondary">← 上一篇</span>
            <p class="text-sm font-medium mt-1 group-hover:text-accent transition-colors truncate">
              {prev.data.title}
            </p>
          </a>
        )}
      </div>
      <div class="flex-1 min-w-0 text-right">
        {next && (
          <a href={postUrl(next.id)} class="group block">
            <span class="text-sm text-text-secondary">下一篇 →</span>
            <p class="text-sm font-medium mt-1 group-hover:text-accent transition-colors truncate">
              {next.data.title}
            </p>
          </a>
        )}
      </div>
    </nav>
  )
}
