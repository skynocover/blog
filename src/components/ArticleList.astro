---
import type { CollectionEntry } from 'astro:content';
import TagFilter from './TagFilter.astro';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;

function formatDate(date: Date): string {
  return `${date.getFullYear()}/${String(date.getMonth() + 1).padStart(2, '0')}/${String(date.getDate()).padStart(2, '0')}`;
}
---

<section class="max-w-180 mx-auto px-6 md:px-8 py-12" id="all-posts">
  <h2 class="text-lg font-semibold mb-6">最新文章</h2>
  <TagFilter />
  <div class="divide-y divide-border">
    {
      posts.map((post) => (
        <article class="py-6 first:pt-0" data-post-tag={post.data.tag}>
          <a href={`/posts/${post.id.replace(/\.md$/, '')}`} class="block group">
            <div class="text-sm text-text-secondary mb-2">
              {post.data.tag} ·{' '}
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            </div>
            <h3 class="text-[1.25rem] font-semibold mb-2 group-hover:text-accent transition-colors leading-snug">
              {post.data.title}
            </h3>
            <p class="text-text-secondary text-sm leading-relaxed">{post.data.description}</p>
          </a>
        </article>
      ))
    }
  </div>
</section>
